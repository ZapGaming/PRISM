# 🌈 PRISM i3 CONFIG - MEGA
set $mod Mod4
font pango: JetBrains Mono Nerd Font 10

# Window borders
default_border pixel 3
default_floating_border pixel 2
hide_edge_borders smart

# Colors - PRISM scheme
client.focused          #7aa2f7 #1a1b26 #c0caf5 #7aa2f7 #7aa2f7
client.unfocused        #24283b #1a1b26 #565f89 #414868 #414868
client.urgent           #f7768e #1a1b26 #f7768e #f7768e #f7768e

# Gaps gaps inner 15
gaps outer 0
smart_gaps on
smart_borders on

# Startup exec_always --no-startup-id xrdb ~/.Xresources
exec_always --no-startup-id feh --bg-fill ~/.config/prism/wallpapers/wave.glsl.png
exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
exec_always --no-startup-id polybar main
exec_always --no-startup-id dunst -conf ~/.config/dunst/dunstrc
exec --no-startup-id nm-applet
exec --no-startup-id blueman-applet
exec --no-startup-id flameshot

# Keybinds
bindsym $mod+Return exec kitty
bindsym $mod+d exec rofi -show drun -config ~/.config/rofi/prism.rasi
bindsym $mod+Shift+q kill
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec i3-msg exit

# Media keys
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

